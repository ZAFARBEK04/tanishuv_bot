# Telegram bot tokeni (@BotFather dan oling)
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MongoDB ulanish manzili (MongoDB Atlas — bepul tier yetarli, yoki Railway MongoDB plugin)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/tanishuv_bot

# Railway avtomatik beradigan domen, https:// VA oxiridagi / siz
# Masalan: tanishuv-bot-production.up.railway.app
# Bo'sh qoldirilsa, bot POLLING rejimida ishlaydi (sekinroq, lekin webhook sozlash shart emas)
PUBLIC_URL=

# Port (Railway o'zi avtomatik beradi, lokalda 3000 ishlatiladi)
PORT=3000

# Profilni ochish narxi (so'mda)
PROFILE_PRICE=5000

# --- TELEGRAM PAYMENTS PROVIDER TOKEN ---
# BotFather → /mybots → Botingiz → Payments → to'lov provayderini tanlang
# (sizda Ammer Pay Live ulangan) → tokenni shu yerga qo'ying
# Format namunasi: 5775769170:LIVE:TG_xxxxxxxxxxxxxxxxxxxx
PAYMENT_PROVIDER_TOKEN=

# Admin(lar) Telegram ID'lari, vergul bilan ajratilgan (masalan: 123456789,987654321)
ADMIN_IDS=
